{
  "builds": [
    {
      "src": "gharaakar/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/backend/wsgi.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "15mb" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/backend/wsgi.py" },
    { "source": "/admin/(.*)", "destination": "/backend/backend/wsgi.py" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}